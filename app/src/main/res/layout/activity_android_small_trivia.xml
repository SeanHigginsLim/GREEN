<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:background="#FFFFFF"
	android:clipChildren="false"
	android:clipToPadding="false"
	android:orientation="vertical"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:fitsSystemWindows="true">
	<ScrollView
		android:clipChildren="false"
		android:clipToPadding="false"
		android:id="@+id/rvjnz8ckxmsp"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:background="#FFFFFF">
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:clipChildren="false"
			android:clipToPadding="false"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/rpowfbivyztm"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical"
				android:background="#ABE098"
				android:paddingVertical="7dp"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/home_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="center_horizontal"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/rtpmb3sfkxec"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:scaleType="fitXY"
					/>
					<TextView
						android:id="@+id/rxsmpub6ngab"
						android:textColor="#FFFFFF"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="Home"
					/>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/trivia_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="center_horizontal"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/rv2mkds8qk"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:scaleType="fitXY"
					/>
					<TextView
						android:id="@+id/rpkmco15mhc"
						android:textColor="#000000"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="Trivia"
					/>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/map_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="center_horizontal"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/rm8ia53ujvf"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:scaleType="fitXY"
					/>
					<TextView
						android:id="@+id/rpxyvojvhv8t"
						android:textColor="#FFFFFF"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="Map"
					/>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/profile_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="center_horizontal"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/rwt2433i01up"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:scaleType="fitXY"
					/>
					<TextView
						android:id="@+id/r4yhujriqbjd"
						android:textColor="#FFFFFF"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="Profile"
					/>
				</LinearLayout>
			</LinearLayout>

			<TextView
				android:id="@+id/rzp8mx1hks0k"
				android:layout_width="218dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="29dp"
				android:layout_marginBottom="1dp"
				android:text="Welcome to G.R.E.E.N. Tour Companion!"
				android:textColor="#000000"
				android:textSize="20sp"
				android:textStyle="bold" />

			<LinearLayout
				android:id="@+id/ryyr5k91pzg"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical"
				android:background="@drawable/cr4bffffff"
				android:paddingVertical="8dp"
				android:paddingHorizontal="16dp"
				android:layout_marginBottom="7dp"
				android:layout_marginHorizontal="30dp"
				android:elevation="4dp"
				android:orientation="horizontal"
				android:layout_marginTop="10dp">
				<ImageView
					android:id="@+id/rjr0kuafq29l"
					android:layout_width="44dp"
					android:layout_height="42dp"
					android:layout_marginEnd="21dp"
					android:scaleType="fitXY"
				/>
				<LinearLayout
					android:id="@+id/rbipaa0046e4"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:orientation="vertical">
					<TextView
						android:id="@+id/rti4sfe28rzp"
						android:textColor="#228B22"
						android:textSize="7sp"
						android:layout_marginStart="1dp"
						android:layout_height="wrap_content"
						android:layout_width="45dp"
						android:text="Did you know?"
					/>
					<TextView
						android:id="@+id/ril02vaww56"
						android:textColor="#000000"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="CAMPUS TRIVIA"
					/>
					<TextView
						android:id="@+id/triviaText"
						android:textColor="#6D7680"
						android:textSize="10sp"
						android:layout_marginHorizontal="1dp"
						android:layout_height="wrap_content"
						android:layout_width="match_parent"
						android:layout_weight="1"
						android:text="Loading trivia..."
						/>

				</LinearLayout>

			</LinearLayout>

			<LinearLayout
				android:id="@+id/shareTriviaButton"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginHorizontal="30dp"
				android:layout_marginBottom="10dp"
				android:background="@drawable/cr2b57c84d"
				android:clickable="true"
				android:focusable="true"
				android:gravity="center"
				android:minHeight="48dp"
				android:orientation="vertical"
				android:paddingVertical="8dp">

				<TextView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Share a trivia!"
					android:textColor="#FFFFFF"
					android:textSize="14sp"
					android:textStyle="bold" />
			</LinearLayout>
		</LinearLayout>
	</ScrollView>

	<LinearLayout
		android:id="@+id/r4ms0xexbden"
		android:layout_width="match_parent"
		android:layout_height="80dp"
		android:layout_marginBottom="20dp"
		android:layout_marginHorizontal="30dp"
		android:clipChildren="false"
		android:clipToPadding="false"
		android:orientation="horizontal">
		<RelativeLayout
			android:id="@+id/rh7bai8e3pin"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:layout_marginEnd="9dp"
			android:clipChildren="false"
			android:clipToPadding="false"
			>
			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:clipChildren="false"
				android:clipToPadding="false"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/r3nbi4xpq42p"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:background="@drawable/cr4bf0ffeb"
					android:paddingVertical="10dp"
					android:paddingLeft="14dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/relmd3axkst8"
						android:textColor="#3F3F3F"
						android:textSize="10sp"
						android:layout_height="wrap_content"
						android:layout_width="103dp"
						android:text="See Full Map"
						/>
					<TextView
						android:id="@+id/rurenvbruly"
						android:textColor="#228B22"
						android:textSize="7sp"
						android:layout_height="wrap_content"
						android:layout_width="86dp"
						android:text="Discover what’s around with an easy-to-use map."
						/>
				</LinearLayout>
			</LinearLayout>
			<ImageView
				android:id="@+id/rybdh3kflfnm"
				android:layout_width="45dp"
				android:layout_height="37dp"
				android:layout_marginBottom="-1dp"
				android:layout_marginEnd="-2dp"
				android:layout_alignParentBottom="true"
				android:layout_alignParentRight="true"
				android:scaleType="fitXY"
				/>
		</RelativeLayout>
		<LinearLayout
			android:id="@+id/rijut4xpsfv"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:layout_weight="1"
			android:background="@drawable/cr4bf1ffec"
			android:paddingVertical="8dp"
			android:paddingHorizontal="11dp"
			android:clipChildren="false"
			android:clipToPadding="false"
			android:orientation="vertical">
			<TextView
				android:id="@+id/r0s63wfs27gha"
				android:textColor="#3F3F3F"
				android:textSize="10sp"
				android:layout_height="wrap_content"
				android:layout_width="65dp"
				android:text="Ask G.R.E.E.N."
				/>
			<TextView
				android:id="@+id/rlvwcp7ulqvp"
				android:textColor="#228B22"
				android:textSize="7sp"
				android:layout_height="wrap_content"
				android:layout_width="119dp"
				android:text="Explore DLSU with our smart assistant for campus insights at every stop."
				/>
			<LinearLayout
				android:id="@+id/r0eijqj4crskw"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="end"
				android:clipChildren="false"
				android:clipToPadding="false"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/rjuo5tbsq7m"
					android:layout_width="27dp"
					android:layout_height="24dp"
					android:scaleType="fitXY"
					/>
			</LinearLayout>
		</LinearLayout>
	</LinearLayout>
</LinearLayout>

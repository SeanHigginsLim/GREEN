<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:background="#FFFFFF"
	android:orientation="vertical"
	android:layout_width="match_parent"
	android:layout_height="match_parent">

	<RelativeLayout
		android:id="@+id/rundefined_rl_rl"
		android:layout_width="match_parent"
		android:layout_height="match_parent">

		<fragment
			android:id="@+id/map_fragment"
			android:name="com.google.android.gms.maps.SupportMapFragment"
			android:layout_width="match_parent"
			android:layout_height="match_parent" />

		<ImageView
			android:id="@+id/rundefined"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:scaleType="fitXY"
			android:visibility="gone" />

		<LinearLayout
			android:id="@+id/rp4uwa5ytac"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_vertical"
			android:background="#ABE098"
			android:paddingVertical="7dp"
			android:orientation="horizontal">

			<LinearLayout
				android:id="@+id/home_button"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_horizontal"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/rm6mh7dlmac"
					android:layout_width="28dp"
					android:layout_height="28dp"
					android:scaleType="fitXY"/>
				<TextView
					android:id="@+id/r7jqqckfpfqc"
					android:textColor="#FFFFFF"
					android:textSize="12sp"
					android:layout_height="wrap_content"
					android:layout_width="wrap_content"
					android:text="Home"/>
			</LinearLayout>

			<LinearLayout
				android:id="@+id/trivia_button"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_horizontal"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/rr4suqnw5xu8"
					android:layout_width="28dp"
					android:layout_height="28dp"
					android:scaleType="fitXY"/>
				<TextView
					android:id="@+id/r748pn5kq8wa"
					android:textColor="#FFFFFF"
					android:textSize="12sp"
					android:layout_height="wrap_content"
					android:layout_width="wrap_content"
					android:text="Trivia"/>
			</LinearLayout>

			<LinearLayout
				android:id="@+id/map_button"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_horizontal"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/r4ygvniz63xa"
					android:layout_width="28dp"
					android:layout_height="28dp"
					android:scaleType="fitXY"/>
				<TextView
					android:id="@+id/r05o3xhakahf9"
					android:textColor="#000000"
					android:textSize="12sp"
					android:layout_height="wrap_content"
					android:layout_width="wrap_content"
					android:text="Map"/>
			</LinearLayout>

			<LinearLayout
				android:id="@+id/profile_button"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:gravity="center_horizontal"
				android:orientation="vertical">
				<ImageView
					android:id="@+id/resno30rwma6"
					android:layout_width="28dp"
					android:layout_height="28dp"
					android:scaleType="fitXY"/>
				<TextView
					android:id="@+id/r51tetnbgj3b"
					android:textColor="#FFFFFF"
					android:textSize="12sp"
					android:layout_height="wrap_content"
					android:layout_width="wrap_content"
					android:text="Profile"/>
			</LinearLayout>
		</LinearLayout>
	</RelativeLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:gravity="center"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="Create Account"
        android:textColor="#000000"
        android:textSize="24sp"
        android:layout_marginBottom="24dp"  android:layout_height="wrap_content" android:layout_width="wrap_content"/>

    <EditText
        android:id="@+id/signupEmail"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/cr10bffffff" />

    <EditText
        android:id="@+id/signupPassword"
        android:hint="Password"
        android:inputType="textPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/cr10bffffff" />

    <EditText
        android:id="@+id/signupConfirm"
        android:hint="Confirm Password"
        android:inputType="textPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/cr10bffffff" />

    <LinearLayout
        android:id="@+id/signupButton"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/cr10b83d475"
        android:paddingVertical="10dp"
        android:paddingHorizontal="30dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="24dp" android:layout_height="wrap_content" android:layout_width="wrap_content">
        <TextView
            android:text="Sign Up"
            android:textColor="#FFFFFF"
            android:textSize="16sp"  android:layout_height="wrap_content" android:layout_width="wrap_content"/>
    </LinearLayout>

    <TextView
        android:id="@+id/backToLogin"
        android:text="Back to Login"
        android:textColor="#57C84D"
        android:textSize="16sp"  android:layout_height="wrap_content" android:layout_width="wrap_content"/>
</LinearLayout>

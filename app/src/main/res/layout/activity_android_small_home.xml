<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:background="#FFFFFF"
	android:clipChildren="false"
	android:clipToPadding="false"
	android:orientation="vertical"
	android:layout_width="match_parent"
	android:layout_height="match_parent">
	<ScrollView
		android:clipChildren="false"
		android:clipToPadding="false"
		android:id="@+id/r2cjt5ubt95c"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1"
		android:background="#FFFFFF">
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:clipChildren="false"
			android:clipToPadding="false"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/rsrdgiz93v5"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
				android:background="#ABE098"
				android:paddingVertical="7dp"
				android:orientation="horizontal">
				<LinearLayout
					android:id="@+id/home_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="center_horizontal"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/rn6y677xm2op"
						android:layout_width="28dp"
						android:layout_height="28dp"
                        android:contentDescription="@string/go_to_homepage"
						android:scaleType="fitXY"
					/>
					<TextView
						android:id="@+id/rvwt8mbu481"
						android:textColor="#000000"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="Home"
					/>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/trivia_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="center_horizontal"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/r1niin00ofei"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:scaleType="fitXY"
					/>
					<TextView
						android:id="@+id/rig6uncukqc7"
						android:textColor="#FFFFFF"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="Trivia"
					/>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/map_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="center_horizontal"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/ra0p1lhf2i3g"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:scaleType="fitXY"
					/>
					<TextView
						android:id="@+id/r9e4e4idczcq"
						android:textColor="#FFFFFF"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="Map"
					/>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/profile_button"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:gravity="center_horizontal"
					android:orientation="vertical">
					<ImageView
						android:id="@+id/rjvarnxwuapq"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:scaleType="fitXY"
					/>
					<TextView
						android:id="@+id/r87rp57wi2hf"
						android:textColor="#FFFFFF"
						android:textSize="12sp"
						android:layout_height="wrap_content"
						android:layout_width="wrap_content"
						android:text="Profile"
					/>
				</LinearLayout>
			</LinearLayout>

			<LinearLayout
				android:id="@+id/rh50g0u6sug"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:background="#F6F7DD"
				android:paddingBottom="8dp"
				android:clipChildren="false"
				android:clipToPadding="false"
				android:orientation="vertical">
				<RelativeLayout
					android:id="@+id/ry871bdyevcb"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:clipChildren="false"
					android:clipToPadding="false"
					>
					<LinearLayout
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:clipChildren="false"
						android:clipToPadding="false"
						android:orientation="vertical">
						<RelativeLayout
							android:id="@+id/rlqd4vorx07s_rl"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							>
							<ImageView
								android:id="@+id/rlqd4vorx07s"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:scaleType="fitXY"
								/>
							<!--map-->
							<FrameLayout
								android:layout_width="match_parent"
								android:layout_height="250dp"
								android:layout_marginTop="8dp"
								android:layout_marginBottom="12dp"
								android:layout_gravity="center"
								android:elevation="4dp"
								android:clipToOutline="true"
								android:background="@drawable/cr10bffffff">

								<!-- Actual map container -->
								<FrameLayout
									android:id="@+id/home_map_fragment"
									android:layout_width="match_parent"
									android:layout_height="match_parent" />

								<!-- Loading indicator -->
								<ProgressBar
									android:id="@+id/mapLoadingIndicator"
									style="?android:attr/progressBarStyleLarge"
									android:layout_width="60dp"
									android:layout_height="60dp"
									android:layout_gravity="center"
									android:elevation="10dp"
									android:translationZ="10dp"
									android:visibility="gone" />

								<!-- Top-center building/floor overlay -->
								<TextView
									android:id="@+id/currentLocationOverlay"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_gravity="top|center_horizontal"
									android:layout_marginTop="10dp"
									android:background="@drawable/cr10bffffff"
									android:elevation="10dp"
									android:paddingStart="16dp"
									android:paddingEnd="16dp"
									android:paddingTop="8dp"
									android:paddingBottom="8dp"
									android:text="Not in a building"
									android:textColor="#000000"
									android:textSize="13sp"
									android:textStyle="bold"
									android:maxLines="1"
									android:ellipsize="end"
									android:clickable="true"
									android:focusable="true"/>

							</FrameLayout>
						</RelativeLayout>
					</LinearLayout>
				</RelativeLayout>
				<FrameLayout
					android:id="@+id/rykxg21aj92a"
					android:layout_width="match_parent"
					android:layout_height="495dp"
					android:layout_marginHorizontal="18dp"
					android:background="@drawable/cr15bc9ad7f"
					android:clipChildren="false"
					android:clipToPadding="false"
					android:orientation="vertical"
                    android:paddingBottom="13dp">

					<RelativeLayout
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:paddingHorizontal="22dp"
						android:paddingTop="16dp"
						android:paddingBottom="0dp">

						<EditText
							android:id="@+id/r0zz50xix97ik"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:layout_alignParentBottom="true"
							android:background="@drawable/cr10bffffff"
							android:hint="@string/type_here"
							android:imeOptions="actionSend"
							android:inputType="text"
							android:paddingStart="47dp"
							android:paddingEnd="94dp"
							android:paddingVertical="8dp"
							android:textColor="#B9B9B9"
							android:textSize="16sp" />

						<androidx.recyclerview.widget.RecyclerView
							xmlns:tools="http://schemas.android.com/tools"
							android:id="@+id/recyclerViewChatReplies"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:layout_above="@id/r0zz50xix97ik"
							android:layout_alignParentTop="true"
							android:layout_marginBottom="8dp"
							tools:listitem="@android:layout/simple_list_item_1"
							tools:itemCount="10"
                            android:scrollbars="vertical"
                            android:visibility="visible"/>
					</RelativeLayout>
				</FrameLayout>
			</LinearLayout>
		</LinearLayout>
	</ScrollView>
</LinearLayout>
